# Sunucu
PORT=3000
HOST=127.0.0.1
NODE_ENV=production

# JWT — üretimde mutlaka uzun, rastgele değerler kullanın:
#   openssl rand -hex 64
JWT_SECRET=degistir-bunu-openssl-rand-hex-64
JWT_ACCESS_TTL=15m
REFRESH_TTL_DAYS=7

# CORS — panelin erişileceği origin(ler), virgülle ayrılır
CORS_ORIGIN=https://panel.turkiyemcepte.com

# Dosya yöneticisinin gezebileceği kök dizinler (virgülle ayrılır)
ALLOWED_ROOTS=/home,/var/www

# Terminal
TERMINAL_SHELL=/bin/bash

# Dashboard'da durumu izlenecek systemd servisleri (virgülle ayrılır)
MONITORED_SERVICES=nginx,mysql,docker

# SQLite veritabanı dosyası
DB_PATH=./data/panel.db
